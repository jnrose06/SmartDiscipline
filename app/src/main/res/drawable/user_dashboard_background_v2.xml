<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#FFF4E8"
                android:startColor="#FFFDF9" />
        </shape>
    </item>
    <item
        android:left="-70dp"
        android:top="80dp">
        <shape android:shape="oval">
            <size
                android:width="230dp"
                android:height="230dp" />
            <solid android:color="#18FFD89D" />
        </shape>
    </item>
    <item
        android:right="-90dp"
        android:top="300dp">
        <shape android:shape="oval">
            <size
                android:width="260dp"
                android:height="260dp" />
            <solid android:color="#12FFB066" />
        </shape>
    </item>
</layer-list>
