<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#FFF0E4"
                android:startColor="#FFF7F2" />
        </shape>
    </item>
    <item
        android:left="-80dp"
        android:top="120dp">
        <shape android:shape="oval">
            <size
                android:width="260dp"
                android:height="260dp" />
            <solid android:color="#20F7C57C" />
        </shape>
    </item>
    <item
        android:right="-60dp"
        android:top="340dp">
        <shape android:shape="oval">
            <size
                android:width="220dp"
                android:height="220dp" />
            <solid android:color="#1AE0A55A" />
        </shape>
    </item>
</layer-list>
