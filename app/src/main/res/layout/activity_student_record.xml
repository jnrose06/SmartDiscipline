<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student Record Entry"
            android:textColor="#143642"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Add a student record here. The admin dashboard will only show students who already have records."
            android:textColor="#4B6970"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/user_panel_background"
            android:orientation="vertical"
            android:padding="18dp">

            <EditText
                android:id="@+id/etStudentName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/admin_search_background"
                android:hint="Student Username / Full Name"
                android:inputType="textCapWords"
                android:padding="14dp"
                android:textColor="#1D1D1D"
                android:textColorHint="#6E6E6E" />

            <EditText
                android:id="@+id/etStudentId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/admin_search_background"
                android:hint="Student ID"
                android:inputType="text"
                android:padding="14dp"
                android:textColor="#1D1D1D"
                android:textColorHint="#6E6E6E" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <Spinner
                    android:id="@+id/spinnerViolation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/admin_search_background"
                    android:paddingStart="8dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="40dp"
                    android:paddingBottom="8dp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="14dp"
                    android:clickable="false"
                    android:contentDescription="Dropdown arrow"
                    android:focusable="false"
                    android:src="@android:drawable/arrow_down_float"
                    app:tint="#4B6970" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="New records are saved as Pending automatically. Admin can update them to Solved or Unsolved later."
                android:textColor="#5E777D"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnSaveRecord"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/user_logout_button_background"
                android:text="Save Record"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnCancelRecord"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/user_menu_button_background"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#143642"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
