<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#ECF1F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="620dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Hallway background"
                android:scaleType="centerCrop"
                android:src="@drawable/image" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#66211C16" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F2F7FAFD"
                android:elevation="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingTop="10dp"
                android:paddingEnd="18dp"
                android:paddingBottom="10dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/logo" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="SMART DISCIPLINE"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|top"
                android:layout_marginStart="24dp"
                android:layout_marginTop="145dp"
                android:layout_marginEnd="24dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="170dp"
                    android:layout_height="170dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="24dp"
                    android:contentDescription="@string/app_name"
                    android:scaleType="fitCenter"
                    android:src="@drawable/logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="SMART DISCIPLINE. BETTER STUDENT.\nBETTER SCHOOL."
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:text="A smart and transparent platform that helps\nschools manage student conduct while\npromoting a positive learning environment."
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnGetStarted"
                    android:layout_width="176dp"
                    android:layout_height="46dp"
                    android:layout_marginTop="30dp"
                    android:background="@drawable/landing_primary_button"
                    android:text="GET STARTED"
                    android:textAllCaps="true"
                    android:textColor="#111111"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F3FAFE"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="66dp"
            android:paddingEnd="24dp"
            android:paddingBottom="68dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About SMART DISCIPLINE"
                android:textColor="#111111"
                android:textSize="20sp"
                android:textStyle="bold" />

            <View
                android:layout_width="60dp"
                android:layout_height="5dp"
                android:layout_marginTop="12dp"
                android:background="#F1ED3A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="42dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="A positive school culture begins with fairness\nand transparency. SMART DISCIPLINE provides\neducators with smart tools to manage\nbehavior, promote accountability, and support\nstudent growth."
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E7EBF6"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="56dp"
            android:paddingEnd="24dp"
            android:paddingBottom="56dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Key Features"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="44dp"
                android:background="@drawable/landing_feature_card"
                android:elevation="7dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="28dp"
                android:paddingEnd="24dp"
                android:paddingBottom="38dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Violation Tracking"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_marginTop="28dp"
                    android:contentDescription="Violation tracking"
                    android:src="@android:drawable/ic_secure"
                    app:tint="#1E88E5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:gravity="center"
                    android:text="Record and monitor student violations\nefficiently."
                    android:textColor="#111111"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:background="@drawable/landing_feature_card"
                android:elevation="7dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="28dp"
                android:paddingEnd="24dp"
                android:paddingBottom="38dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student Conduct Records"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_marginTop="28dp"
                    android:contentDescription="Student conduct records"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="#1E88E5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:gravity="center"
                    android:text="Maintain organized records of student\nbehaviour."
                    android:textColor="#111111"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
