<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:background="@drawable/user_timeline_card_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvViolationTypeName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="#143642"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvViolationTypeCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/user_small_chip_background"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp"
        android:textColor="#11535F"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>
