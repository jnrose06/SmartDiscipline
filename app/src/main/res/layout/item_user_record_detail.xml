<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="14dp"
    android:background="@drawable/user_timeline_card_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:background="@drawable/user_date_card_background"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvDetailMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#143642"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetailDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#143642"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#143642"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetailDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#597378"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvDetailStatus"
            android:layout_width="132dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:textColor="#17353E"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
