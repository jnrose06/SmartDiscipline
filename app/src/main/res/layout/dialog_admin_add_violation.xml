<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <EditText
            android:id="@+id/etDialogStudentName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/admin_search_background"
            android:hint="Student Username / Full Name"
            android:inputType="textCapWords"
            android:padding="14dp"
            android:textColor="#1D1D1D"
            android:textColorHint="#6E6E6E" />

        <EditText
            android:id="@+id/etDialogStudentId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/admin_search_background"
            android:hint="Student ID"
            android:inputType="text"
            android:padding="14dp"
            android:textColor="#1D1D1D"
            android:textColorHint="#6E6E6E" />

        <Spinner
            android:id="@+id/spinnerDialogViolation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/admin_search_background"
            android:padding="8dp" />

        <Spinner
            android:id="@+id/spinnerDialogStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/admin_search_background"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Date and time will be recorded automatically when you save."
            android:textColor="#5E777D"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
